{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quirks://schemas/task-source-capabilities-v1",
  "type": "object",
  "required": [
    "schemaVersion",
    "protocol",
    "driver",
    "concurrencyStrength",
    "provenanceWriteMode",
    "commentWriteMode",
    "idempotencyLookup",
    "operations",
    "authorityClasses",
    "completionBoundaries",
    "maxRequestBytes",
    "maxResponseBytes"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocol": { "const": "task-source-v1" },
    "driver": { "type": "string", "minLength": 1, "maxLength": 64 },
    "concurrencyStrength": {
      "enum": ["atomic", "optimistic", "local-only", "none"]
    },
    "provenanceWriteMode": {
      "enum": ["structured", "append-only", "none"]
    },
    "commentWriteMode": {
      "enum": ["structured", "append-only", "none"]
    },
    "idempotencyLookup": {
      "enum": ["none", "state", "key"]
    },
    "operations": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "uniqueItems": true,
      "items": {
        "enum": [
          "capabilities",
          "validate",
          "list",
          "show",
          "claim",
          "submit-review",
          "attach-provenance",
          "complete",
          "block",
          "release",
          "propose",
          "verify"
        ]
      }
    },
    "authorityClasses": {
      "type": "array",
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": ["repository", "network", "remote-git", "external-system", "production"]
      }
    },
    "completionBoundaries": {
      "type": "array",
      "maxItems": 4,
      "uniqueItems": true,
      "items": {
        "enum": ["accepted-commit", "campaign-merge", "target-merge", "remote-push"]
      }
    },
    "maxRequestBytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1048576
    },
    "maxResponseBytes": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1048576
    }
  }
}
