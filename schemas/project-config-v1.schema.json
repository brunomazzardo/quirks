{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quirks://schemas/project-config-v1",
  "type": "object",
  "required": ["schemaVersion", "protocol", "taskSource", "workflowPolicy"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "protocol": { "const": "quirks-project-v1" },
    "taskSource": {
      "oneOf": [
        {
          "type": "object",
          "required": ["driver", "path"],
          "additionalProperties": false,
          "properties": {
            "driver": { "const": "json" },
            "path": { "$ref": "#/$defs/repositoryPath" }
          }
        },
        {
          "type": "object",
          "required": ["driver", "command"],
          "additionalProperties": false,
          "properties": {
            "driver": { "const": "external" },
            "command": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "items": { "type": "string", "minLength": 1, "maxLength": 512 }
            },
            "credentialAlias": { "type": "string", "minLength": 1, "maxLength": 128 },
            "credentialEnvironmentNames": {
              "type": "array",
              "minItems": 1,
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 128 }
            }
          }
        }
      ]
    },
    "workflowPolicy": {
      "type": "object",
      "required": ["skills"],
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "write": { "type": "string", "minLength": 1, "maxLength": 128 },
            "update": { "type": "string", "minLength": 1, "maxLength": 128 },
            "execute": { "type": "string", "minLength": 1, "maxLength": 128 }
          }
        },
        "nativeStatusMap": {
          "type": "object",
          "additionalProperties": {
            "enum": ["proposed", "ready", "claimed", "in_review", "blocked", "completed", "cancelled"]
          }
        },
        "evidenceMap": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "accepted-commit": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "uniqueItems": true,
              "items": {
                "enum": ["commit", "campaign-merge", "target-merge", "remote-push", "review", "verification", "ci", "deployment"]
              }
            },
            "campaign-merge": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "uniqueItems": true,
              "items": {
                "enum": ["commit", "campaign-merge", "target-merge", "remote-push", "review", "verification", "ci", "deployment"]
              }
            },
            "target-merge": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "uniqueItems": true,
              "items": {
                "enum": ["commit", "campaign-merge", "target-merge", "remote-push", "review", "verification", "ci", "deployment"]
              }
            },
            "remote-push": {
              "type": "array",
              "minItems": 1,
              "maxItems": 8,
              "uniqueItems": true,
              "items": {
                "enum": ["commit", "campaign-merge", "target-merge", "remote-push", "review", "verification", "ci", "deployment"]
              }
            }
          }
        },
        "allowedCompletionBoundaries": {
          "type": "array",
          "minItems": 1,
          "maxItems": 4,
          "uniqueItems": true,
          "items": {
            "enum": ["accepted-commit", "campaign-merge", "target-merge", "remote-push"]
          }
        }
      }
    }
  },
  "$defs": {
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?!.*\\.\\.)[^\\\\\\0]+$"
    }
  }
}
