{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quirks://schemas/task-provenance-v1",
  "type": "object",
  "required": ["schemaVersion", "iterations"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "const": 1 },
    "iterations": {
      "type": "array",
      "maxItems": 128,
      "items": { "$ref": "#/$defs/iteration" }
    }
  },
  "$defs": {
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024,
      "pattern": "^(?!/)(?!.*\\.\\.)[^\\\\\\0]+$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$",
      "maxLength": 40
    },
    "httpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://[^@/?#]+",
      "maxLength": 2048
    },
    "artifactRef": {
      "type": "object",
      "required": ["kind", "path", "commit"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["spec", "plan", "review", "other"] },
        "path": { "$ref": "#/$defs/repositoryPath" },
        "commit": { "$ref": "#/$defs/gitCommit" },
        "url": { "$ref": "#/$defs/httpsUrl" },
        "task": { "type": "integer", "minimum": 1, "maximum": 9999 },
        "section": { "type": "string", "minLength": 1, "maxLength": 128 },
        "sections": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "items": { "type": "integer", "minimum": 1, "maximum": 999 }
        }
      }
    },
    "identity": {
      "type": "object",
      "required": ["label"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1, "maxLength": 256 },
        "evidence": {
          "enum": [
            "configured-profile",
            "authenticated-host",
            "authenticated-provider",
            "self-asserted",
            "self-asserted-git-metadata",
            "git-signature"
          ]
        },
        "verified": { "type": "boolean" }
      }
    },
    "pullRequestRef": {
      "type": "object",
      "required": ["provider", "repository", "number", "url", "state"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "minLength": 1, "maxLength": 64 },
        "repository": { "type": "string", "minLength": 1, "maxLength": 256 },
        "number": { "type": "integer", "minimum": 1, "maximum": 999999999 },
        "url": { "$ref": "#/$defs/httpsUrl" },
        "state": { "enum": ["open", "closed", "merged", "draft"] },
        "opener": { "$ref": "#/$defs/identity" },
        "merger": { "$ref": "#/$defs/identity" },
        "mergeCommit": { "$ref": "#/$defs/gitCommit" }
      }
    },
    "verificationRef": {
      "type": "object",
      "required": ["kind", "reference", "outcome"],
      "additionalProperties": false,
      "properties": {
        "kind": { "enum": ["verification", "ci", "build", "release", "deployment"] },
        "reference": { "type": "string", "minLength": 1, "maxLength": 512 },
        "outcome": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "participant": {
      "type": "object",
      "required": ["role"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "minLength": 1, "maxLength": 64 },
        "runner": { "type": "string", "minLength": 1, "maxLength": 128 },
        "model": { "type": "string", "minLength": 1, "maxLength": 128 },
        "effort": { "enum": ["mechanical", "standard", "high", "principal"] },
        "sessionRef": { "type": "string", "minLength": 1, "maxLength": 256 }
      }
    },
    "iteration": {
      "type": "object",
      "required": ["id", "outcome", "completionBoundary"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "maxLength": 128
        },
        "campaignId": { "type": "string", "minLength": 1, "maxLength": 128 },
        "taskRevision": { "type": "string", "minLength": 1, "maxLength": 128 },
        "envelopeDigest": { "type": "string", "minLength": 1, "maxLength": 128 },
        "outcome": {
          "enum": ["completed", "partial", "failed", "cancelled", "blocked", "superseded"]
        },
        "completionBoundary": {
          "enum": ["accepted-commit", "campaign-merge", "target-merge", "remote-push"]
        },
        "baseCommit": { "$ref": "#/$defs/gitCommit" },
        "acceptedCommit": { "$ref": "#/$defs/gitCommit" },
        "landedCommit": { "$ref": "#/$defs/gitCommit" },
        "supersededBy": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
          "maxLength": 128
        },
        "artifactRefs": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/artifactRef" }
        },
        "commitRefs": {
          "type": "array",
          "maxItems": 256,
          "items": { "$ref": "#/$defs/gitCommit" }
        },
        "pullRequestRefs": {
          "type": "array",
          "maxItems": 16,
          "items": { "$ref": "#/$defs/pullRequestRef" }
        },
        "verificationRefs": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/verificationRef" }
        },
        "participants": {
          "type": "array",
          "maxItems": 32,
          "items": { "$ref": "#/$defs/participant" }
        },
        "operator": { "$ref": "#/$defs/identity" },
        "gitAuthor": { "$ref": "#/$defs/identity" },
        "gitCommitter": { "$ref": "#/$defs/identity" },
        "startedAt": { "type": "string", "format": "date-time", "maxLength": 64 },
        "finishedAt": { "type": "string", "format": "date-time", "maxLength": 64 },
        "durationMs": { "type": "integer", "minimum": 0, "maximum": 31536000000 },
        "usage": { "type": "string", "minLength": 1, "maxLength": 256 },
        "cost": { "type": "string", "minLength": 1, "maxLength": 256 },
        "deviations": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 512 }
        },
        "retries": { "type": "integer", "minimum": 0, "maximum": 1000 },
        "fallbacks": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "permissionDenials": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "timeouts": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "resumptions": {
          "type": "array",
          "maxItems": 16,
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        },
        "followUpTaskRefs": {
          "type": "array",
          "maxItems": 32,
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$",
            "maxLength": 128
          }
        },
        "outcomeReason": { "type": "string", "minLength": 1, "maxLength": 512 }
      }
    }
  }
}
